<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="60dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_media_previous"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/text_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Trip:"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Form card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp">

            <!-- Route Code -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Route Code"
                style="@style/LabelText"/>

            <Spinner
                android:id="@+id/spinnerRouteCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Bus/Jeep Code + Vehicle Assignment row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bus/Jeep Code"
                        style="@style/LabelText"/>

                    <Spinner
                        android:id="@+id/spinnerBusCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vehicle Assignment"
                        style="@style/LabelText"/>

                    <EditText
                        android:id="@+id/etVehicleAssignment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Bus/Jeep"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Start Point -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Point"
                style="@style/LabelText"/>

            <EditText
                android:id="@+id/etStartPoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="origin"
                style="@style/InputField"/>

            <!-- End Point -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="End Point"
                style="@style/LabelText"/>

            <EditText
                android:id="@+id/etEndPoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="destination"
                style="@style/InputField"/>

            <!-- Departure Time + Plate Number -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Departure Time"
                        style="@style/LabelText"/>

                    <Spinner
                        android:id="@+id/spinnerDepartureTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Plate Number"
                        style="@style/LabelText"/>

                    <EditText
                        android:id="@+id/etPlateNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="ABD123"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Assigned Driver -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Assigned Driver"
                style="@style/LabelText"/>

            <EditText
                android:id="@+id/etAssignedDriver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Juan Dela Cruz"
                style="@style/InputField"/>

            <!-- Assigned Conductor -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Assigned Conductor"
                style="@style/LabelText"/>

            <EditText
                android:id="@+id/etAssignedConductor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pedro Garcia"
                style="@style/InputField"/>

            <!-- Contact Info -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contact Info:"
                style="@style/LabelText"/>

            <EditText
                android:id="@+id/etContactInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+63**********"
                android:inputType="phone"
                style="@style/InputField"/>

            <!-- Maintenance Status + Trip Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Trip Status:"
                        style="@style/LabelText"/>

                    <Spinner
                        android:id="@+id/spinnerTripStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Add Trip button -->
            <Button
                android:id="@+id/btnAddTrip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Trip"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/bg_button_green"
                android:paddingHorizontal="28dp"
                android:paddingVertical="12dp"
                android:layout_gravity="end"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>